# Copy to `.env.local` for local dev. Set the same keys in Vercel → Settings → Environment Variables (Production).

# Hosted PostgreSQL only on Vercel — never use localhost here for production.
# Add ?sslmode=require if your provider needs it. For Neon/Supabase serverless, prefer the *pooler* connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Required in production (Auth.js v5). Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Local only — do NOT set http://localhost on Vercel (breaks login live).
# NEXTAUTH_URL="http://localhost:3000"
# Or: AUTH_URL="http://localhost:3000"

# Optional: production canonical URL (or omit; inferred with trustHost on Vercel).
# AUTH_URL="https://your-app.vercel.app"

ADMIN_EMAIL=
ADMIN_SECRET=
