# Copy to `.env.local` for local dev. Set the same keys in Vercel → Settings → Environment Variables (Production).

# Hosted PostgreSQL only on Vercel — never use localhost here for production.
# Add ?sslmode=require if your provider needs it. For Neon/Supabase serverless, prefer the *pooler* connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Required in production (Auth.js v5). Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Local only — do NOT set http://localhost on Vercel (breaks login live).
# NEXTAUTH_URL="http://localhost:3000"
# Or: AUTH_URL="http://localhost:3000"

# Optional: production canonical URL (or omit; inferred with trustHost on Vercel).
# AUTH_URL="https://your-app.vercel.app"

ADMIN_EMAIL=
ADMIN_SECRET=

# Vercel Cron (team auto withdraw-suspend sweep): set in Vercel → Environment Variables; same value secures GET /api/cron/team-withdraw-suspend
# CRON_SECRET=

# Optional: IANA timezone for admin “today” commission stats (default UTC). Example: Asia/Karachi
# ADMIN_STATS_TZ=Asia/Karachi

# Activation fee: default true = L1–L20 × $0.50 to uplines, remainder to admin (same as deposits). Set false for legacy full $10 to admin every activation.
# ACTIVATION_DISTRIBUTE_TO_UPLINES=true

# Optional: dedicated BSC JSON-RPC (helps on Vercel if public RPC rate-limits).
# BSC_RPC_URL="https://bsc-dataseed1.binance.org"

# Local dev: phone on same WiFi — add your PC LAN URL (comma-separated) to silence Next cross-origin warnings.
# ALLOWED_DEV_ORIGINS=http://192.168.1.10:3000
