{
  "name": "my-mlm-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "set NEXT_DEV_SKIP_TS_SETUP_WRITE=1&& set NEXT_DEV_SKIP_APP_TYPE_WRITE=1&& node --require=./scripts/set-node-path.cjs --require=./scripts/next-fetch-guard.cjs ./node_modules/next/dist/bin/next dev --webpack -p 3000 -H 127.0.0.1",
    "dev:turbo": "set NEXT_DEV_SKIP_TS_SETUP_WRITE=1&& set NEXT_DEV_SKIP_APP_TYPE_WRITE=1&& node --require=./scripts/set-node-path.cjs --require=./scripts/next-fetch-guard.cjs ./node_modules/next/dist/bin/next dev --turbo -p 3000 -H 127.0.0.1",
    "db:generate": "npx prisma generate && node scripts/link-prisma-client.cjs",
    "db:push": "npx prisma db push --skip-generate",
    "db:reset": "prisma migrate reset --force --skip-seed",
    "build": "npx prisma generate && node scripts/link-prisma-client.cjs && next build --webpack",
    "postinstall": "npx prisma generate && node scripts/link-prisma-client.cjs",
    "start": "node --require=./scripts/set-node-path.cjs ./node_modules/next/dist/bin/next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@next/env": "16.2.2",
    "@prisma/client": "^5.22.0",
    "@prisma/engines": "7.6.0",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@reown/appkit": "^1.8.19",
    "@swc/helpers": "^0.5.20",
    "@tanstack/react-query": "^5.91.2",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "mysql2": "^3.19.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "react-toastify": "^11.0.5",
    "viem": "^2.47.5",
    "wagmi": "^2.19.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
