generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  blocked
  admin
}

enum TransactionType {
  deposit
  commission
  adjustment
}

enum NotificationType {
  commission
  support
  system
}

enum TicketStatus {
  open
  closed
}

enum OtpPurpose {
  registration
  withdrawal
  password_reset
}

enum DepositStatus {
  pending
  confirmed
  rejected
}

enum Chain {
  BSC
}

enum WithdrawalStatus {
  pending
  approved
  rejected
}

model User {
  id           String     @id @default(cuid())
  username     String
  country      String     @default("")
  email        String     @unique
  passwordHash String
  walletAddress String    @unique
  referrerCode String     @unique
  referredById String?
  referredBy   User?      @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]     @relation("UserReferrals")
  balance      Decimal    @default(0) @db.Decimal(18, 2)
  status       UserStatus @default(active)
  emailVerifiedAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  transactions        Transaction[] @relation("UserTransactions")
  sourceTransactions  Transaction[] @relation("SourceUserTransactions")
  notifications       Notification[]
  supportTickets      SupportTicket[]
  otps                Otp[]
  deposits            Deposit[]
  withdrawals         Withdrawal[]

  @@index([referredById])
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  sourceUserId String
  level        Int
  amount       Decimal         @db.Decimal(18, 2)
  type         TransactionType
  note         String          @default("")
  createdAt    DateTime        @default(now())

  user       User @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)
  sourceUser User @relation("SourceUserTransactions", fields: [sourceUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sourceUserId])
  @@index([type])
}

model Setting {
  id               String   @id @default(cuid())
  key              String   @unique
  levelPercentages Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(system)
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}

model SupportTicket {
  id        String      @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    TicketStatus @default(open)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Otp {
  id        String     @id @default(cuid())
  userId    String?
  email     String
  purpose   OtpPurpose
  codeHash  String
  attempts  Int        @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@index([userId])
  @@index([expiresAt])
}

model Deposit {
  id         String       @id @default(cuid())
  userId     String
  chain      Chain        @default(BSC)
  txHash     String       @unique
  amount     Decimal      @db.Decimal(18, 2)
  status     DepositStatus @default(pending)
  verifiedAt DateTime?
  createdAt  DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Withdrawal {
  id         String            @id @default(cuid())
  userId     String
  address    String
  amount     Decimal           @db.Decimal(18, 2)
  status     WithdrawalStatus  @default(pending)
  txHash     String?           @unique
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}
